# ---- Anthropic ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- NextAuth ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Required when running in Docker or behind a reverse proxy
AUTH_TRUST_HOST=true
# When using the Docker stack, host port is 3001 (see docker-compose.yml).
AUTH_URL=http://localhost:3001

# ---- Azure Deployment (optional, for Deploy & Test) ----
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=

# ---- Infracost (optional, for real-time cloud pricing) ----
# Get a free API key at https://dashboard.infracost.io
# Without this, /api/cost-estimate falls back to the built-in RESOURCE_COSTS map
# and the UI shows a "Fallback estimate" amber badge.
INFRACOST_API_KEY=

# ---- MCP Servers (official Terraform + Azure integrations) ----
# Set to "false" to disable either integration (tools degrade gracefully).
ENABLE_TERRAFORM_MCP=true
ENABLE_AZURE_MCP=true
# URL used by the app container to reach the terraform-mcp sidecar. Default
# matches docker-compose service name + internal port.
TERRAFORM_MCP_URL=http://terraform-mcp:8080/mcp

# ---- Expert Mode ----
# Model ID used when a user toggles Expert Mode on in the UI. Defaults to the
# stable Opus 4.7 alias; override to a specific snapshot (e.g.
# claude-opus-4-7-20260115) without a code change. Opus runs cost ~5× Sonnet.
OPUS_MODEL_ID=claude-opus-4-7

# ---- Redis (optional, for production rate limiting) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Database (optional, for persistence layer) ----
DATABASE_URL=postgresql://terrain:terrain@localhost:5432/terrain

# ---- Redis (optional, for conversion caching) ----
REDIS_URL=redis://localhost:6379

# ---- Logging ----
LOG_LEVEL=info

# ---- Node ----
NODE_ENV=development
