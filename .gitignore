# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but always keep the example template
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ephemeral conversion outputs (generated Terraform from past runs; 100s of MB)
/terraform/
/terraform-output/

# office temp / lock files
~$*.pptx
~$*.docx
~$*.xlsx
